<Window x:Class="ExamsResults.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExamsResults"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="1000">
    <Grid>
        <Grid.Resources>
            <Style TargetType="Button" x:Key="GreenRoundedButton">
                <Setter Property="Background" Value="#4CAF50" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="24,0" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Content="Поиск:" 
               VerticalAlignment="Center" 
               Margin="0,0,8,0" />

            <TextBox Grid.Column="1"
                 Margin="0,0,12,0"
                 VerticalAlignment="Center"
                 Height="28" />

            <ComboBox Grid.Column="2"
                  Width="160"
                  Height="28"
                  VerticalAlignment="Center"
                  SelectedIndex="0">
                <ComboBoxItem Content="Все записи" IsSelected="True"/>
                <ComboBoxItem Content="Сдал"/>
                <ComboBoxItem Content="Не сдал"/>
            </ComboBox>
        </Grid>

        <DataGrid x:Name="dataGridExams"
              Grid.Row="1"
              Margin="8,0,8,4"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="All"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Auto"
              CanUserResizeColumns="True"
              CanUserSortColumns="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название предмета" 
                                Width="*" 
                                Binding="{Binding НазваниеПредмета}" />

                <DataGridTextColumn Header="дата экзамена" 
                                Width="120" 
                                Binding="{Binding ДатаЭкзамена}" />

                <DataGridTextColumn Header="Имя экзаменатора" 
                                Width="*" 
                                Binding="{Binding ИмяЭкзаменатора}" />

                <DataGridTextColumn Header="Имя студента" 
                                Width="*" 
                                Binding="{Binding ИмяСтудента}" />

                <DataGridTextColumn Header="Группа студента" 
                                Width="140" 
                                Binding="{Binding ГруппаСтудента}" />

                <DataGridTextColumn Header="Результат: Сдал / Не сдал" 
                                Width="180" 
                                Binding="{Binding Результат}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="8,4,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Content="Добавить Элемент"
                Grid.Column="0"
                Style="{StaticResource GreenRoundedButton}" Click="Button_Click" />

            <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                <Button Content="&lt;" 
                    Width="36" 
                    Height="36" 
                    Margin="0,0,4,0" />

                <TextBlock Text="1" 
                       VerticalAlignment="Center" 
                       Margin="12,0" 
                       FontSize="16" />

                <Button Content="&gt;" 
                    Width="36" 
                    Height="36" 
                    Margin="4,0,0,0" />

            </StackPanel>
        </Grid>
    </Grid>
</Window>
