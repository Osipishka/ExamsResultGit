<Window x:Class="ExamsResults.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExamsResults"
        mc:Ignorable="d"
        Title="LoginWindow" Height="450" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Name="TitlePril" Text="Вход" VerticalAlignment="Center" FontSize="20"/>
        </StackPanel>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
            <StackPanel>
                <TextBlock Name="EmailBlock" Text="Email" VerticalAlignment="Center" Margin="0 0 0 5"/>
                <TextBox Name="Email" Text="" VerticalAlignment="Center"  Width="200" TextChanged="Email_TextChanged"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Name="PassBlock" Text="Pass" VerticalAlignment="Center" Margin="0 10 0 5"/>
                <TextBox Name="Pass" Text="" VerticalAlignment="Center" Width="200"/>
            </StackPanel>
            
        </StackPanel>
        
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2">
            <Button Name="LoginBTN" Width="100" Height="25" Click="LoginBTN_Click">
                <TextBlock Text="Войти"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
