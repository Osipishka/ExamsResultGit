<Window x:Class="ExamsResults.AddExamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExamsResults"
        mc:Ignorable="d"
        Title="AddExamWindow" Height="450" Width="800">
    <Border BorderBrush="Black" 
        BorderThickness="4" 
        Padding="30"
        Background="White">

        <Grid>
            <!-- Ресурсы: зелёная кнопка (точно как в главном окне) -->
            <Grid.Resources>
                <Style TargetType="Button" x:Key="GreenRoundedButton">
                    <Setter Property="Background" Value="#4CAF50" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="Padding" Value="28,0" />
                    <Setter Property="Height" Value="42" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Название + Дата -->
                <RowDefinition Height="Auto" />
                <!-- Имя экзаменатора -->
                <RowDefinition Height="Auto" />
                <!-- Имя студента -->
                <RowDefinition Height="Auto" />
                <!-- Группа студента -->
                <RowDefinition Height="Auto" />
                <!-- Чекбокс + Кнопка -->
            </Grid.RowDefinitions>

            <!-- 1. Верхняя строка: Название предмета (слева) + Дата проведения (справа) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280" />
                    <ColumnDefinition Width="Auto" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <!-- Название предмета -->
                <StackPanel Grid.Column="0" Margin="0,0,30,0">
                    <Label Content="Название предмета"
                       FontSize="14"
                       Margin="0,0,0,6" />
                    <TextBox Height="38"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         Padding="10,0" />
                </StackPanel>

                <!-- Дата проведения -->
                <StackPanel Grid.Column="1">
                    <Label Content="Дата проведения"
                       FontSize="14"
                       Margin="0,0,0,6" />
                    <DatePicker Height="38"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            Padding="8,0"
                            SelectedDateFormat="Short" />
                </StackPanel>
            </Grid>

            <!-- 2. Имя Экзаменатора (полная ширина) -->
            <StackPanel Grid.Row="1" Margin="0,28,0,0">
                <Label Content="Имя Экзаменатора"
                   FontSize="14"
                   Margin="0,0,0,6" />
                <TextBox Height="38"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="10,0" />
            </StackPanel>

            <!-- 3. Имя студента (полная ширина) -->
            <StackPanel Grid.Row="2" Margin="0,22,0,0">
                <Label Content="Имя студента"
                   FontSize="14"
                   Margin="0,0,0,6" />
                <TextBox Height="38"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="10,0" />
            </StackPanel>

            <!-- 4. Группа студента (полная ширина) -->
            <StackPanel Grid.Row="3" Margin="0,22,0,0">
                <Label Content="Группа студента"
                   FontSize="14"
                   Margin="0,0,0,6" />
                <TextBox Height="38"
                     FontSize="14"
                     VerticalContentAlignment="Center"
                     Padding="10,0" />
            </StackPanel>

            <!-- 5. Нижняя строка: чекбокс + зелёная кнопка -->
            <Grid Grid.Row="4" Margin="0,36,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Чекбокс "Сдал" -->
                <CheckBox Grid.Column="0"
                      Content="Сдал"
                      FontSize="14"
                      VerticalAlignment="Center"
                      Margin="4,0,0,0" />

                <!-- Зелёная кнопка "Добавить" -->
                <Button Grid.Column="2"
                    Content="Добавить"
                    Style="{StaticResource GreenRoundedButton}" />
            </Grid>
        </Grid>
    </Border>
</Window>
